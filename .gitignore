.DS_Store

# Node (prevent accidentally installing packages in root)
node_modules/
package-lock.json

# ignore the temporary example project used for new-particle-background work
/new background/

*.jsonl
*.json
!data/lance/schema_version.json
!frontend/package.json
!frontend/package-lock.json
!frontend/tsconfig.json

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.pytest_cache/
.coverage

# Virtual environments
.venv/

# Local data artifacts
/data/
/testing/
*.pdf
*.txt

# Local databases
*.sqlite
*.db

# Chroma persistence
chroma/

# Local models (keep directory placeholders)
/models/
!models/.gitkeep

*.md
